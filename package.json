{
  "name": "logseq-synapses-monorepo",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "author": "qoob23",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "knip": "knip",
    "typecheck": "tsc -p packages/core --noEmit && tsc -p packages/logseq-plugin --noEmit && tsc -p packages/obsidian-plugin --noEmit",
    "build": "npm run build -w @synapses/core && npm run build -w logseq-plugin && npm run build -w obsidian-plugin"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "knip": "^6.23.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
